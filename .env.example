# Telegram (required for bot)
BOT_TOKEN=

# Paths (defaults suit Docker: /app/data/schedules.json)
SCHEDULES_PATH=data/schedules.json
USER_PREFS_PATH=data/user_groups.json

# Scraper: Bitrix filter property IDs from the site form (update if the site changes)
SCRAPE_BASE_URL=https://www.kgasu.ru/student/raspisanie-zanyatiy/
SCRAPE_TIP_RASP=107
SCRAPE_UCH_GOD=236
SCRAPE_SEMESTR=94

# Docker profile `scheduler`: seconds to wait after each scrape before the next (default 21600 = 6 h)
# SCRAPE_INTERVAL_SEC=21600

# Scraper: pause after each listing page on the main Bitrix site (alias: SCRAPE_DELAY_SEC)
# SCRAPE_LISTING_DELAY_SEC=0.5

# Bot: reload schedules.json from disk every N seconds (0 = mtime polling only)
SCHEDULE_RELOAD_SEC=300
SCHEDULE_POLL_SEC=60

# Timezone for today/tomorrow
TZ=Europe/Moscow
